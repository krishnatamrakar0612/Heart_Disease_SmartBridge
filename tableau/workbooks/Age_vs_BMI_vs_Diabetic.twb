      <column caption='diabetic' datatype='string' name='[Calculation_1587465692196878]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Diabetic] = &quot;No&quot; THEN NULL&#13;&#10;ELSEIF [Diabetic] = &quot;No, borderline diabetes&quot; THEN NULL&#13;&#10;ELSE [Diabetic]&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Age sort' datatype='integer' name='[Calculation_1587465697656850]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='CASE [AgeCategory]&#13;&#10;&#13;&#10;WHEN &quot;18-24&quot; THEN 1&#13;&#10;WHEN &quot;25-29&quot; THEN 2&#13;&#10;WHEN &quot;30-34&quot; THEN 3&#13;&#10;WHEN &quot;35-39&quot; THEN 4&#13;&#10;WHEN &quot;40-44&quot; THEN 5&#13;&#10;WHEN &quot;45-49&quot; THEN 6&#13;&#10;WHEN &quot;50-54&quot; THEN 7&#13;&#10;WHEN &quot;55-59&quot; THEN 8&#13;&#10;WHEN &quot;60-64&quot; THEN 9&#13;&#10;WHEN &quot;65-69&quot; THEN 10&#13;&#10;WHEN &quot;70-74&quot; THEN 11&#13;&#10;WHEN &quot;75-79&quot; THEN 12&#13;&#10;WHEN &quot;80 or older&quot; THEN 13&#13;&#10;&#13;&#10;END' />
      </column>
